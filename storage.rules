rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Cada pessoa só pode enviar/substituir a própria foto de perfil.
    // A leitura é pública (qualquer um com o link direto da imagem
    // consegue vê-la) — é assim que a maioria dos apps trata avatar,
    // já que a própria foto não costuma ser informação sensível, mas
    // vale você saber dessa escolha.
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
